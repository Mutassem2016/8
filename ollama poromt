// ── الـ simple block parser ──────────────────────────────────────────
// لغة مبسّطة جوه Pazzle — بتدعم print وinput وتلوين
class parseSimpleClass {
  color(line) {
    let m = line.match(/(.+?)\s*\(\s*(.+?)\s*\)/);
    if (!m) return null;
    let id = "";
    switch (m[1].trim()) {
      case "red":    id = "31"; break;
      case "green":  id = "32"; break;
      case "yellow": id = "33"; break;
      case "blue":   id = "34"; break;
      case "purple": id = "35"; break;
      case "cyan":   id = "36"; break;
      default:       id = "0";
    }
    return `console.log("\\x1b[${id}m${m[2]}\\x1b[0m")`;
  }
}

// ── نقطة البداية ─────────────────────────────────────────────────────
function startCompilation() {
  const target = process.argv[2];

  // لو مفيش arguments أو طلب help
  if (!target || target === "--help" || target === "-h") {
    printHelp();
    process.exit(0);
  }

  // اجمع الـ arguments الإضافية للـ Input()
  newInputsInCMD = [];
  for (let i = 3; i < process.argv.length; i++) {
    newInputsInCMD.push(process.argv[i]);
  }

  const isWatch = process.argv.includes("-w");

  // دالة بتكمبايل كل الـ .pazzle files في الـ directory الحالية
  const compileAll = () => {
    const files = fs.readdirSync(process.cwd()).filter(f => f.endsWith(".pazzle"));
    if (files.length === 0) { console.log("No .pazzle files found in current directory."); return; }
    files.forEach(file => {
      try { parsePazzle(path.resolve(file)); }
      catch (err) { console.error(`Error in ${file}: ${err.message}`); }
    });
  };

  if (isWatch) {
    // Watch mode — بيراقب التغييرات ويعيد الكمبايل تلقائياً
    PazzleInfo("👀 Pazzle is watching for changes...", '');
    fs.watch(process.cwd(), (eventType, filename) => {
      if (filename && filename.endsWith(".pazzle")) {
        console.log(`\n📄 File changed: ${filename}. Recompiling...`);
        try { parsePazzle(path.resolve(filename)); }
        catch (err) { console.error(`Error: ${err.message}`); }
      }
    });
  } else if (target === "." || target === "-all") {
    compileAll();
  } else {
    // كمبايل ملف واحد
    const fullPath = path.resolve(target);
    if (fs.existsSync(fullPath)) {
      try { parsePazzle(fullPath); }
      catch (err) { console.error(`Error: ${err.message}`); }
    } else {
      console.error(`❌ Error: File not found -> ${target}`);
      process.exit(1);
    }
  }
}

// ─── Helper Functions ────────────────────────────────────────────────

// بيشوف لو string فيها substring
function has(str, substr) { return str.includes(substr); }

// بيرجع رقم السطر اللي فيه الـ substring
function getLineHas(joinedArea, substr) {
  const lines = joinedArea.split("\n");
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].includes(substr)) return i;
  }
  return -1;
}

// ─── parseSimple ────────────────────────────────────────────────────
// بيعالج الـ simple block — لغة مبسّطة جوه Pazzle
// بيدعم: print بـ quotes، input تفاعلي، تلوين
// state بتتبرر عشان يسجّل المتغيرات صح
function parseSimple(code, lineNo, state) {
  let depth   = 1;
  EPnum++;
  let codeTwo = code.split('\n');
  let i       = -1;
  let endLine = 0;
  let result  = [];

  while (i < codeTwo.length) {
    if (lineNo + i >= codeTwo.length) break;

    let line = codeTwo[lineNo + i].trim();

    if (!line || line.startsWith('#')) { i++; continue; }

    if (line.includes("{")) depth++;
    if (line.includes("}")) {
      depth--;
      if (depth === 0) { endLine = i; break; }
    }

    // "text" → print مباشر
    if (line.startsWith('"') && line.endsWith('"')) {
      let mtwo = line.match(/"(.+?)"/);
      result.push(`console.log("${mtwo[1]}")`);
      i++; continue;
    }

    // 'text' → print مباشر
    if (line.startsWith("'") && line.endsWith("'")) {
      let mtwo = line.match(/'(.+?)'/);
      result.push(`console.log('${mtwo[1]}')`);
      i++; continue;
    }

    // varName share in show Input("prompt") → readline input
    let m = line.match(/(.+?)\s+share\s+in\s+(.+)/);
    if (m) {
      let mtwo = m[2].trim().match(/show\s+Input\((.*)?\)/);
      if (mtwo) {
        const prompt  = mtwo[1] ? mtwo[1] : '';
        const varName = m[1].trim();
        if (state) state.addVariable(varName, 'let');

        // أعمل الـ readline system مرة واحدة بس في البرنامج كله
        if (qcount === 0) {
          result.push(
            `if (!global.__pazzle_rl) {\n` +
            `  const __rl_mod = require('readline');\n` +
            `  // output: null يمنع echo الـ input على الشاشة\n` +
            `  global.__pazzle_rl = __rl_mod.createInterface({ input: process.stdin, output: null, terminal: false });\n` +
            `  global.__pazzle_queue = [];\n` +
            `  global.__pazzle_lines = [];\n` +
            `  global.__pazzle_rl.on('line', (l) => {\n` +
            `    if (global.__pazzle_queue.length > 0) {\n` +
            `      global.__pazzle_queue.shift()(l); // شيل أول callback وشغّله\n` +
            `    } else {\n` +
            `      global.__pazzle_lines.push(l); // خزّن للـ input الجاي\n` +
            `    }\n` +
            `  });\n` +
            `}\n` +
            `function __pazzleAsk(prompt) {\n` +
            `  return new Promise((resolve) => {\n` +
            `    if (global.__pazzle_lines.length > 0) {\n` +
            `      resolve(global.__pazzle_lines.shift()); // لو في سطر جاهز، استخدمه\n` +
            `    } else {\n` +
            `      if (prompt) process.stdout.write(prompt);\n` +
            `      global.__pazzle_queue.push(resolve); // استنّى الـ user يكتب\n` +
            `    }\n` +
            `  });\n` +
            `}`
          );
        }
        qcount++;
        result.push(`let ${varName} = await __pazzleAsk(${JSON.stringify(prompt)});`);
        i++; continue;
      }
      // share in value — تخزين في jsonArea
      if (state) state.addVariable(m[1].trim(), 'let');
      result.push(`jsonArea['${m[1]}'] = ${m[2]}`);
      i++; continue;
    }

    // assignment عادي
    m = line.match(/(.+?)\s*=\s*(.+)/);
    if (m) { result.push(line); i++; continue; }

    // تلوين: color(text)
    m = line.match(/(.+?)\s*\(\s*(.+?)\s*\)/);
    if (m) {
      const classS  = new parseSimpleClass();
      const colored = classS.color(line);
      if (colored) result.push(colored);
      i++; continue;
    }

    i++;
  }

  return { i: endLine + 1, code: result.join('\n') };
}

