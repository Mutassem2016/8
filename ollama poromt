// parseVarEditorLine
// بيحلل سطر زي: score: add(10)
// ويرجع { varName: "score", property: "add", value: "10" }
// لو مش بالشكل ده، بيرجع null
// ═══════════════════════════════════════════════════════════════════════
function parseVarEditorLine(line) {
  const colonIdx = line.indexOf(':');
  if (colonIdx === -1) return null;

  const left = line.substring(0, colonIdx).trim();          // اسم المتغير
  const rest = line.substring(colonIdx + 1).trim();         // property(value)
  const parenIdx = rest.indexOf('(');
  if (parenIdx === -1) return null;

  const property  = rest.substring(0, parenIdx).trim();     // اسم العملية
  const lastParen = rest.lastIndexOf(')');
  if (lastParen === -1) return null;

  const value = rest.substring(parenIdx + 1, lastParen).trim(); // القيمة

  // تأكد إن الـ property اسم صحيح
  if (!/^[A-Za-z_]\w*$/.test(property)) return null;

  return { varName: left, property, value };
}

