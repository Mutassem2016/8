// VariableEditor
// بينفّذ عمليات تعديل المتغيرات
// مثال: score: add(10)  →  score += 10;
// ═══════════════════════════════════════════════════════════════════════
class VariableEditor {
  constructor(state) { this.state = state; }

  parse(varNames, property, value, lineNo) {
    const names = varNames.split(",").map(v => v.trim());
    const js    = [];

    for (const v of names) {
      // تحذير لو المتغير مش معلن
      if (!this.state.isVariable(v))  PazzleWarn(lineNo, `Variable '${v}' not declared`);
      // خطأ لو حاولت تعدّل ثابت
      if (this.state.isConstant(v))   PazzleError(lineNo, `Cannot modify constant '${v}'`);
      const result = this.applyOperation(v, property, value, lineNo);
      if (result) js.push(result);
    }
    return js;
  }

  applyOperation(varName, property, value, lineNo) {
    // take هي عملية خاصة — تنقل قيمة من متغير لآخر
    if (property === 'take') return this.parseTake(varName, value, lineNo);

    if (property in varEditorInputs) {
      // استبدل "var" بالاسم الحقيقي و"value" بالقيمة
      return varEditorInputs[property].replace(/var/g, varName).replace(/value/g, value);
    }
    PazzleError(lineNo, `Unknown property '${property}'`);
  }

  // take: ينقل قيمة من متغير للتاني
  // مثال: x: take(y, 5)  →  x += 5; y -= 5;
  parseTake(varName, value, lineNo) {
    const values = value.split(",").map(v => v.trim());
    if (values.length !== 2) {
      PazzleError(lineNo, `'take' expects exactly 2 arguments, got ${values.length}: ${value}`);
      return null;
    }
    return `${varName} += ${values[1]}; ${values[0]} -= ${values[1]};`;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// FunctionParser
// بيعالج تعريف الدوال في Pazzle
// الشكل: catch fnName { ... }
// ═══════════════════════════════════════════════════════════════════════
class FunctionParser {
  constructor(state) { this.state = state; }

  parse(fnName, lines, startIndex) {
    this.state.addFunction(fnName);
    this.state.inFunction = true;

    const js = [];
    js.push(`function ${fnName}(){`);

    let depth = 1;
    let i     = startIndex + 1;

    while (i < lines.length && depth > 0) {
      const line = lines[i].trim();

      // تجاهل الفراغات والـ comments
      if (!line || line.startsWith("#")) { i++; continue; }

      const openCount  = (line.match(/\{/g) || []).length;
      const closeCount = (line.match(/\}/g) || []).length;

      if (line === "}") {
        depth--;
        if (depth === 0) { js.push("}"); break; }
        js.push("}");
        i++;
        continue;
      }

      depth += openCount - closeCount;

      const parsed = this.parseFunctionLine(line, i + 1);
      if (parsed) {
        if (Array.isArray(parsed)) js.push(...parsed.map(l => "  " + l));
        else js.push("  " + parsed);
      } else {
        if (line !== "{") PazzleWarn(i + 1, `Unrecognized syntax in function: ${line}`);
      }
      i++;
    }

    this.state.inFunction = false;
    return { code: js, endIndex: i };
  }

  // نفس منطق الـ parser الرئيسي بس داخل الـ function
  parseFunctionLine(line, lineNo) {
    const printHandler = new PrintHandler(this.state);
    const varEditor    = new VariableEditor(this.state);
    let m;

    // إعلان متغير
    m = line.match(/^make\s+([A-Za-z_]\w*)\s*=\s*(.+)$/);
    if (m) { this.state.addVariable(m[1], 'let'); return `let ${m[1]} = ${m[2]};`; }

    // إعلان ثابت
    m = line.match(/^stop\s+([A-Za-z_]\w*)\s*=\s*(.+)$/);
    if (m) { this.state.addVariable(m[1], 'const'); return `const ${m[1]} = ${m[2]};`; }

    // print داخل الدالة
    m = line.match(/^local\.My's\.web\.txtar\s*\(\s*(print|link|reprint|Up|printUp|down|printDown)\((.+?)\)\s*\)$/);
    if (m) return printHandler.parse(m[1], m[2], lineNo);

    // raw JS مباشر
    m = line.match(/^runJS:\s*(.+)$/);
    if (m) return m[1].trim();

    // built-in functions (term/math/str/arr)
    const _builtin = parseBuiltinCall(line, this.state);
    if (_builtin) return _builtin;

    // for loop داخل الدالة
    m = line.match(/^for\s+([A-Za-z_]\w*)\s+from\s+(.+?)\s+to\s+(.+?)(?:\s+step\s+(.+?))?\s*\{$/);
    if (m) {
      const [, vn, st, en, sp] = m;
      return `for(let ${vn}=${st}; ${vn}<${en}; ${vn}+=${sp || '1'}){`;
    }

    // while داخل الدالة
    m = line.match(/^while\((.+?)\)\{$/);
    if (m) {
      const parsedC = new ExpressionParser(this.state).parseComparisons(m[1]);
      return `while(${parsedC}){`;
    }

    // keywords أساسية
    if (line === '}')       return '}';
    if (line === 'break')   return 'break;';
    if (line === 'continue') return 'continue;';

    // Array operations — شيل الـ varEditor عشان ما يأكلهاش
    m = line.match(/^([A-Za-z_]\w*)\s*:\s*(.+)$/);
    if (m && this.state.isVariable(m[1])) {
      const op       = m[2].trim();
      const isArrOp  = /^(push|pop|shift|unshift|reverse|sort|clear|remove|get\(|set\(|slice|includes|indexOf|join|length)/.test(op);
      if (isArrOp) {
        const arrRes = new ArrayHandler(this.state).parseArrayOp(m[1], op, lineNo);
        if (arrRes) return arrRes;
      }
    }

    // variable editor
    const _ve = parseVarEditorLine(line);
    if (_ve) return varEditor.parse(_ve.varName, _ve.property, _ve.value, lineNo);

    // write file
    m = line.match(/^write\s*\(\s*(.+?)\s*,\s*(.+?)\s*\)$/);
    if (m) return `fs.writeFileSync(${m[1]}, ${m[2]}, "utf8");`;

    // return value
    m = line.match(/^return\s+(.+)$/);
    if (m) return `return ${m[1]};`;

    // if داخل الدالة
    m = line.match(/^if\((.+?)\)\{$/);
    if (m) {
      const parsedC = new ExpressionParser(this.state).parseComparisons(m[1]);
      return `if(${parsedC}){`;
    }

    // function call
    m = line.match(/^call\s+([A-Za-z_]\w*)\s*\((.*?)\)$/);
    if (m) return `${m[1]}(${m[2]});`;

    // onKey داخل الدالة
    m = line.match(/^onKey\(([A-Za-z_]\w*)\)\s*\{$/);
    if (m) return `if (global.__pazzle_keys && global.__pazzle_keys['${m[1]}']) {`;

    return null;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// ConditionalParser
// بيعالج الـ if/else/else if في Pazzle
// الشكل: if(condition){ ... }else{ ... }
// ═══════════════════════════════════════════════════════════════════════
class ConditionalParser {
  constructor(state) { this.state = state; }

  parse(condition, lines, startIndex) {
    this.state.inConditional = true;
    const js = [];
    js.push(`if(${condition}){`);

    let depth = 1;
    let i     = startIndex + 1;

    while (i < lines.length && depth > 0) {
      const line = lines[i].trim();
      if (!line || line.startsWith("#")) { i++; continue; }

      const openCount  = (line.match(/\{/g) || []).length;
      const closeCount = (line.match(/\}/g) || []).length;

      // }else if(cond){ — شرط إضافي
      if (line.startsWith("}else if(")) {
        const elseIfMatch = line.match(/\}else if\((.+?)\)\{/);
        if (elseIfMatch) {
          depth += openCount - closeCount;
          js.push(`}else if(${elseIfMatch[1]}){`);
          i++;
          continue;
        }
      }

      // }else{ — الفرع البديل
      if (line.startsWith("}else") || line.startsWith("} else")) {
        js.push("}else{");
        i++;
        continue;
      }

      depth += openCount - closeCount;
      if (depth <= 0) { js.push("}"); break; }

      const parsed = this.parseConditionalLine(line, i + 1);
      if (parsed) {
        if (Array.isArray(parsed)) js.push(...parsed.map(l => "  " + l));
        else js.push("  " + parsed);
      }
      i++;
    }

    this.state.inConditional = false;
    return { code: js, endIndex: i };
  }

  // نفس المنطق بس داخل الـ conditional
  parseConditionalLine(line, lineNo) {
    const printHandler = new PrintHandler(this.state);
    const varEditor    = new VariableEditor(this.state);
    let m;

    // raw JS أولاً قبل أي حاجة تانية
    m = line.match(/^runJS:\s*(.+)$/);
    if (m) return m[1].trim();

    const _builtin = parseBuiltinCall(line, this.state);
    if (_builtin) return _builtin;

    m = line.match(/^local\.My's\.web\.txtar\s*\(\s*(print|link|reprint|Up|printUp|down|printDown)\((.+?)\)\s*\)$/);
    if (m) return printHandler.parse(m[1], m[2], lineNo);

    const _ve = parseVarEditorLine(line);
    if (_ve) return varEditor.parse(_ve.varName, _ve.property, _ve.value, lineNo);

    m = line.match(/^call\s+([A-Za-z_]\w*)\s*\((.*?)\)$/);
    if (m) return `${m[1]}(${m[2]});`;

    if (line.startsWith("if(")) return line;

    m = line.match(/^onKey\(([A-Za-z_]\w*)\)\s*\{$/);
    if (m) return `if (global.__pazzle_keys && global.__pazzle_keys['${m[1]}']) {`;

    if (line === '}')     return '}';
    if (line === 'break') return 'break;';

    // Array ops داخل الـ conditional
    m = line.match(/^([A-Za-z_]\w*)\s*:\s*(.+)$/);
    if (m && this.state.isVariable(m[1])) {
      const op      = m[2].trim();
      const isArrOp = /^(push|pop|shift|unshift|reverse|sort|clear|remove|get\(|set\(|slice|includes|indexOf|join|length)/.test(op);
      if (isArrOp) {
        const arrRes = new ArrayHandler(this.state).parseArrayOp(m[1], op, lineNo);
        if (arrRes) return arrRes;
      }
      const _ve2 = parseVarEditorLine(m[0]);
      if (_ve2) return new VariableEditor(this.state).parse(_ve2.varName, _ve2.property, _ve2.value, lineNo);
    }
    return null;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// LoopParser
// بيعالج الـ loops في Pazzle:
//   - interval loop: loop_to.end.time({n}[{ ... }]
//   - for loop: for i from 0 to 10 { ... }
// ═══════════════════════════════════════════════════════════════════════
class LoopParser {
  constructor(state) { this.state = state; }

  // Interval loop — بيتكرر كل n ثانية
  parseInterval(delay, lines, startIndex) {
    this.state.inLoop = true;
    const js      = [];
    const delayMs = Number(delay) * 1000; // حوّل للـ milliseconds
    js.push(`setInterval(()=>{`);

    let i      = startIndex + 1;
    let closed = false;

    while (i < lines.length) {
      const line = lines[i].trim();
      if (!line || line.startsWith("#")) { i++; continue; }

      // }] هو الـ closing token للـ interval loop
      if (line.includes("}]")) {
        js.push(`}, ${delayMs});`);
        closed = true;
        break;
      }

      const parsed = this.parseLoopLine(line, i + 1);
      if (parsed) {
        if (Array.isArray(parsed)) js.push(...parsed.map(l => "  " + l));
        else js.push("  " + parsed);
      }
      i++;
    }

    // لازم يلاقي }] — لو لأ، خطأ صريح
    if (!closed) PazzleError(startIndex + 1, `Unclosed interval loop — missing '}]' token`);

    this.state.inLoop = false;
    return { code: js, endIndex: i };
  }

  // For loop — بيعدّ من start لـ end بخطوة step
  parseFor(varName, start, end, step, lines, startIndex) {
    const js        = [];
    const stepValue = step || 1;
    js.push(`for(let ${varName} = ${start}; ${varName} <= ${end}; ${varName} += ${stepValue}){`);

    let i     = startIndex + 1;
    let depth = 1;

    while (i < lines.length && depth > 0) {
      const line = lines[i].trim();
      if (!line || line.startsWith("#")) { i++; continue; }

      const openCount  = (line.match(/\{/g) || []).length;
      const closeCount = (line.match(/\}/g) || []).length;
      depth += openCount - closeCount;

      if (depth <= 0) { js.push("}"); break; }

      const parsed = this.parseLoopLine(line, i + 1);
      if (parsed) {
        if (Array.isArray(parsed)) js.push(...parsed.map(l => "  " + l));
        else js.push("  " + parsed);
      }
      i++;
    }

    return { code: js, endIndex: i };
  }

  // السطور المسموحة داخل الـ loops
  parseLoopLine(line, lineNo) {
    const printHandler = new PrintHandler(this.state);
    const varEditor    = new VariableEditor(this.state);
    let m;

    m = line.match(/^local\.My's\.web\.txtar\s*\(\s*(print|link|reprint|Up|printUp|down|printDown)\((.+?)\)\s*\)$/);
    if (m) return printHandler.parse(m[1], m[2], lineNo);

    m = line.match(/^runJS:\s*(.+)$/);
    if (m) return m[1].trim();

    const _builtin = parseBuiltinCall(line, this.state);
    if (_builtin) return _builtin;

    const _ve = parseVarEditorLine(line);
    if (_ve) return varEditor.parse(_ve.varName, _ve.property, _ve.value, lineNo);

    // Array ops داخل الـ loop
    m = line.match(/^([A-Za-z_]\w*)\s*:\s*(.+)$/);
    if (m && this.state.isVariable(m[1])) {
      const op      = m[2].trim();
      const isArrOp = /^(push|pop|shift|unshift|reverse|sort|clear|remove|get\(|set\(|slice|includes|indexOf|join|length)/.test(op);
      if (isArrOp) {
        const arrRes = new ArrayHandler(this.state).parseArrayOp(m[1], op, lineNo);
        if (arrRes) return arrRes;
      }
    }

    m = line.match(/^onKey\(([A-Za-z_]\w*)\)\s*\{$/);
    if (m) return `if (global.__pazzle_keys && global.__pazzle_keys['${m[1]}']) {`;

    m = line.match(/^make\s+([A-Za-z_]\w*)\s*=\s*(.+)$/);
    if (m) { this.state.addVariable(m[1], 'let'); return `let ${m[1]} = ${m[2]};`; }

    m = line.match(/^call\s+([A-Za-z_]\w*)\s*\((.*?)\)$/);
    if (m) return `${m[1]}(${m[2]});`;

    m = line.match(/^if\((.+?)\)\{$/);
    if (m) {
      const parsedC = new ExpressionParser(this.state).parseComparisons(m[1]);
      return `if(${parsedC}){`;
    }

    if (line === 'break')    return 'break;';
    if (line === 'continue') return 'continue;';
    if (line === '}')        return '}';

    return null;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// WhileParser
// بيعالج الـ while loop
// الشكل: while(condition){ ... }
// ═══════════════════════════════════════════════════════════════════════
class WhileParser {
  constructor(state) { this.state = state; }

  parse(condition, lines, startIndex) {
    const js         = [];
    const parsedCond = new ExpressionParser(this.state).parseComparisons(condition);
    js.push(`while(${parsedCond}){`);

    let depth = 1;
    let i     = startIndex + 1;

