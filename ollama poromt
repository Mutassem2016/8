// ParserState
// بيخزّن كل حاجة عن الحالة الحالية للـ parser:
// المتغيرات، الدوال، الثوابت، الـ imports، وغيرهم
// ═══════════════════════════════════════════════════════════════════════
class ParserState {
  constructor() {
    this.js           = [];          // سطور الـ JavaScript الناتجة
    this.variables    = new Set();   // أسماء المتغيرات المعلنة
    this.functions    = new Set();   // أسماء الدوال المعلنة
    this.constants    = new Set();   // أسماء الثوابت (const)
    this.imports      = new Set();   // الـ modules المستوردة
    this.styleElements = new Map();  // عناصر الـ CSS
    this.htmlElements  = new Map();  // عناصر الـ HTML
    this.loops        = [];          // stack الـ loops الحالية
    this.conditionals = [];          // stack الـ conditionals
    this.inFunction   = false;       // هل احنا جوه function دلوقتي؟
    this.inLoop       = false;       // هل احنا جوه loop؟
    this.inConditional = false;      // هل احنا جوه conditional؟
    this.depth        = 0;           // عمق الـ nesting الحالي
    this.inMatch      = false;       // هل احنا جوه match statement؟
    this.depthMatch   = 0;           // عمق الـ match
  }

  // سجّل متغير جديد (let أو const)
  addVariable(name, type = 'let') {
    this.variables.add(name);
    if (type === 'const') this.constants.add(name);
  }

  addFunction(name)  { this.functions.add(name); }
  addImport(moduleName) { this.imports.add(moduleName); }

  isVariable(name)  { return this.variables.has(name); }
  isFunction(name)  { return this.functions.has(name); }
  isConstant(name)  { return this.constants.has(name); }

  // أضف سطر JS للـ output
  addJS(line) { this.js.push(line); }

  // جمّع الـ output النهائي
  // لو في أي await → لفّ كل الكود في async IIFE
  // عشان:
  //   1) await يشتغل في CommonJS
  //   2) المتغيرات تبقى في نفس الـ scope
  getOutput() {
    const body = this.js.join("\n");
    if (body.includes("await ")) {
      const closeRl = `if (global.__pazzle_rl) global.__pazzle_rl.close();`;
      return `(async () => {\n${body}\n${closeRl}\n})().catch(err => { console.error("[Pazzle Async Error]:", err.message); });`;
    }
    return body;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// ExpressionParser
// بيعالج التعبيرات الحسابية والمقارنات
// مثال: "x greater than 5" → "x > 5"
// ═══════════════════════════════════════════════════════════════════════
class ExpressionParser {
  constructor(state) { this.state = state; }

  parse(expr, lineNo) {
    let e = expr.trim();

    // "call fn(" → "fn(" مع تحذير لو الدالة مش معرّفة
    e = e.replace(/call\s+([A-Za-z_]\w*)\s*\(/g, (_, fn) => {
      if (!this.state.isFunction(fn)) PazzleWarn(lineNo, `Calling undefined function '${fn}'`);
      return `${fn}(`;
    });

    e = e.replace(/\s*\+\s*/g, ' + ');
    e = this.parseArithmetic(e);
    e = this.parseComparisons(e);
    e = this.balanceParentheses(e, lineNo);
    return e;
  }

  parseArithmetic(expr) {
    // حالياً مش بيعمل تحويل — الـ arithmetic بيتعامل معه مباشرة
    return expr;
  }

  // حوّل الكلمات لـ operators مقارنة
  parseComparisons(expr) {
    expr = expr.replace(/\s+equals\s+/g,       ' === ');
    expr = expr.replace(/\s+not\s+equals\s+/g, ' !== ');
    expr = expr.replace(/\s+greater\s+than\s+/, ' > ');
    expr = expr.replace(/\s+less\s+than\s+/,    ' < ');
    return expr;
  }

  // تأكد إن الأقواس متوازنة — لو لأ ارمي error صريح
  balanceParentheses(expr, lineNo) {
    let open = 0;
    for (let c of expr) {
      if (c === "(") open++;
      else if (c === ")") open--;
    }
    if (open > 0)  PazzleError(lineNo, `Expression has ${open} unclosed parenthesis: ${expr}`);
    if (open < 0)  PazzleError(lineNo, `Expression has ${Math.abs(open)} extra closing parenthesis: ${expr}`);
    return expr;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// PrintHandler
// بيتعامل مع كل أنواع الـ print في Pazzle
// ═══════════════════════════════════════════════════════════════════════
class PrintHandler {
  constructor(state) { this.state = state; }

  parse(type, expr, lineNo) {
    const exprParser = new ExpressionParser(this.state);
    const e = exprParser.parse(expr, lineNo);

    // تحقق من صحة التعبير قبل الـ print
    const isString     = e.startsWith('"') || e.startsWith("'");
    const isNumber     = !isNaN(e) && e.trim() !== '';
    const isFnCall     = e.includes("(");
    const isVariable   = /^[A-Za-z_]\w*/.test(e);
    const isExpression = /[+\-*/%]/.test(e);

    if (!isString && !isNumber && !isFnCall && !isVariable && !isExpression) {
      PazzleError(lineNo, `Cannot print '${e}': Invalid expression`);
    }

    // كل نوع print ليه سلوك مختلف
    if (type === "print")     return `__Pazzle_Print__(${e});`;                          // سطر جديد
    if (type === "link")      return `process.stdout.write(${e});`;                      // بدون سطر
    if (type === "reprint")   return `process.stdout.write('\\r' + ${e});`;              // rewrite نفس السطر
    if (type === "Up")        return `process.stdout.write('\\x1b[${e}A');`;             // تحرك للفوق
    if (type === "printUp")   return `process.stdout.write('\\x1b[${e.split(',')[0]}A' + ${e.split(',')[1]});`;
    if (type === "down")      return `process.stdout.write('\\x1b[${e}B');`;             // تحرك للتحت
    if (type === "printDown") return `process.stdout.write('\\x1b[${e.split(',')[0]}B' + ${e.split(',')[1]});`;
    return null;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// RegexHandler
// بيتعامل مع الـ Regular Expressions في Pazzle
// بيستخدم syntax مبسّط بدل الـ regex العادي
// مثال: (num) → \d+  ,  (word) → \w+
// ═══════════════════════════════════════════════════════════════════════
class RegexHandler {
  constructor(state) { this.state = state; }

  parse(varName, pattern, targets, lineNo) {
    let regexPattern = this.convertPattern(pattern);
    const js = [];
    js.push(`const ${varName}Match = ${varName}.match(/${regexPattern}/);`);
    js.push(`if(${varName}Match){`);
    const targetList = targets.split(",").map(t => t.trim());
    targetList.forEach((t, index) => {
      this.state.addVariable(t);
      js.push(`  const ${t} = ${varName}Match[${index}];`);
    });
    return js;
  }

  // حوّل الـ Pazzle regex syntax للـ JS regex الحقيقي
  convertPattern(pattern) {
    let p = pattern;
    p = p.replace(/\(num\)/g,    "\\d+");
    p = p.replace(/\(word\)/g,   "\\w+");
    p = p.replace(/\(any\)/g,    ".+");
    p = p.replace(/\(letter\)/g, "[a-zA-Z]");
    p = p.replace(/\(digit\)/g,  "\\d");
    p = p.replace(/\(numCL\)/g,  "\\d+?");
    p = p.replace(/\(wordCL\)/g, "\\w+?");
    p = p.replace(/\(anyCL\)/g,  ".+?");
    p = p.replace(/\(_\)/g,      "\\s*");
    p = p.replace(/ /g,          "\\s+");
    p = p.replace(/\(dot\)/g,    "\\.");
    // مهم: (|) الأول عشان ما نغلطش مع | العادي
    p = p.replace(/\(\|\)/g,     "\\|");
    p = p.replace(/\|/g,         "");
    p = p.replace(/b\(/g,        "\\(");
    p = p.replace(/b\)/g,        "\\)");
    return p;
  }

  closeBlock() { return "}"; }
}

